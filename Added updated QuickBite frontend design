<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QuickBite</title>

  <style>
    * {
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      margin: 0;
      min-height: 100vh;
      color: white;
      background:
        linear-gradient(rgba(5, 8, 20, 0.9), rgba(5, 8, 20, 0.95)),
        url("https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=1600&q=80");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }

    .container {
      width: 92%;
      max-width: 1200px;
      margin: 30px auto;
    }

    .header {
      text-align: center;
      margin-bottom: 28px;
    }

    .logo {
      width: 85px;
      height: 85px;
      margin: auto;
      border-radius: 50%;
      background: linear-gradient(135deg, #ff4d4d, #ffb347);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
      box-shadow: 0 0 30px rgba(255, 179, 71, 0.5);
    }

    .header h1 {
      margin: 12px 0 5px;
      font-size: 44px;
    }

    .header span {
      color: #ffb347;
    }

    .header p {
      margin: 0;
      color: #ddd;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 25px;
    }

    .card {
      background: rgba(14, 18, 34, 0.94);
      border: 1px solid rgba(255,255,255,0.13);
      border-radius: 24px;
      padding: 28px;
      box-shadow: 0 15px 45px rgba(0,0,0,0.5);
    }

    h2 {
      margin-top: 0;
      color: #ffb347;
      font-size: 30px;
    }

    label {
      display: block;
      margin-bottom: 7px;
      font-weight: bold;
    }

    input, select {
      width: 100%;
      padding: 14px;
      margin-bottom: 16px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.08);
      color: white;
      font-size: 15px;
      outline: none;
    }

    select option {
      color: black;
    }

    .menu {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
      margin-bottom: 20px;
    }

    .food-item {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      padding: 14px;
      border-radius: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: 0.3s;
    }

    .food-item:hover {
      transform: translateY(-3px);
      border-color: #ffb347;
    }

    .food-item h4 {
      margin: 0;
      color: #ffb347;
    }

    .food-item p {
      margin: 4px 0 0;
      color: #eee;
    }

    .food-item input {
      width: 65px;
      margin: 0;
      text-align: center;
    }

    .bill-box {
      background: rgba(255, 179, 71, 0.12);
      border: 1px solid rgba(255, 179, 71, 0.35);
      padding: 15px;
      border-radius: 16px;
      margin-bottom: 18px;
    }

    .bill-box h3 {
      margin: 0;
      color: #ffb347;
    }

    button {
      width: 100%;
      padding: 15px;
      border: none;
      border-radius: 16px;
      background: linear-gradient(90deg, #ff4d4d, #ffb347);
      color: white;
      font-size: 18px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(255, 120, 50, 0.5);
    }

    .message {
      display: none;
      padding: 12px;
      border-radius: 12px;
      margin-bottom: 15px;
      font-weight: bold;
    }

    .success {
      background: rgba(40, 167, 69, 0.22);
      color: #8df5a6;
      border: 1px solid #28a745;
    }

    .error {
      background: rgba(220, 53, 69, 0.22);
      color: #ff9aa5;
      border: 1px solid #dc3545;
    }

    .order-list {
      display: flex;
      flex-direction: column;
      gap: 15px;
      max-height: 620px;
      overflow-y: auto;
      padding-right: 5px;
    }

    .order-item {
      background: linear-gradient(135deg, rgba(255,77,77,0.16), rgba(255,179,71,0.10));
      border-left: 5px solid #ffb347;
      padding: 16px;
      border-radius: 16px;
    }

    .order-item h4 {
      margin: 0 0 8px;
      color: #ffb347;
      font-size: 20px;
    }

    .order-item p {
      margin: 5px 0;
      color: #f1f1f1;
    }

    .badge {
      display: inline-block;
      background: #ffb347;
      color: #111;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: bold;
      margin-top: 6px;
    }

    @media (max-width: 900px) {
      .grid {
        grid-template-columns: 1fr;
      }

      .menu {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="header">
      <div class="logo">🍔</div>
      <h1>Quick<span>Bite</span></h1>
      <p>Professional Food Ordering System</p>
    </div>

    <div class="grid">
      <div class="card">
        <h2>🍽️ Place Order</h2>

        <div id="messageBox" class="message"></div>

        <label>Customer Name</label>
        <input id="name" type="text" placeholder="Enter customer name">

        <label>Phone Number</label>
        <input id="phone" type="text" placeholder="Enter phone number">

        <label>Select Items & Quantity</label>

        <div class="menu">
          <div class="food-item">
            <div><h4>Burger</h4><p>Rs 300</p></div>
            <input type="number" min="0" value="0" data-food="Burger" data-price="300" oninput="updateBill()">
          </div>

          <div class="food-item">
            <div><h4>Pizza</h4><p>Rs 800</p></div>
            <input type="number" min="0" value="0" data-food="Pizza" data-price="800" oninput="updateBill()">
          </div>

          <div class="food-item">
            <div><h4>Shawarma</h4><p>Rs 250</p></div>
            <input type="number" min="0" value="0" data-food="Shawarma" data-price="250" oninput="updateBill()">
          </div>

          <div class="food-item">
            <div><h4>Biryani</h4><p>Rs 500</p></div>
            <input type="number" min="0" value="0" data-food="Biryani" data-price="500" oninput="updateBill()">
          </div>

          <div class="food-item">
            <div><h4>Pulao</h4><p>Rs 450</p></div>
            <input type="number" min="0" value="0" data-food="Pulao" data-price="450" oninput="updateBill()">
          </div>

          <div class="food-item">
            <div><h4>Fries</h4><p>Rs 200</p></div>
            <input type="number" min="0" value="0" data-food="Fries" data-price="200" oninput="updateBill()">
          </div>

          <div class="food-item">
            <div><h4>Nuggets</h4><p>Rs 350</p></div>
            <input type="number" min="0" value="0" data-food="Nuggets" data-price="350" oninput="updateBill()">
          </div>

          <div class="food-item">
            <div><h4>Cold Drink</h4><p>Rs 120</p></div>
            <input type="number" min="0" value="0" data-food="Cold Drink" data-price="120" oninput="updateBill()">
          </div>

          <div class="food-item">
            <div><h4>Juice</h4><p>Rs 180</p></div>
            <input type="number" min="0" value="0" data-food="Juice" data-price="180" oninput="updateBill()">
          </div>

          <div class="food-item">
            <div><h4>Ice Cream</h4><p>Rs 150</p></div>
            <input type="number" min="0" value="0" data-food="Ice Cream" data-price="150" oninput="updateBill()">
          </div>
        </div>

        <label>Payment Method</label>
        <select id="paymentMethod">
          <option value="Cash">Cash</option>
          <option value="Card">Card</option>
        </select>

        <div class="bill-box">
          <h3 id="billText">Total Bill: Rs 0</h3>
        </div>

        <button onclick="placeOrder()">Place Order</button>
      </div>

      <div class="card">
        <h2>🧾 Recent Orders</h2>
        <div id="orders" class="order-list"></div>
      </div>
    </div>
  </div>

  <script>
    function showMessage(text, type) {
      const box = document.getElementById("messageBox");
      box.style.display = "block";
      box.className = "message " + type;
      box.textContent = text;
    }

    function getSelectedItems() {
      const inputs = document.querySelectorAll(".food-item input");
      let items = [];

      inputs.forEach(input => {
        const quantity = parseInt(input.value);

        if (quantity > 0) {
          items.push({
            food: input.dataset.food,
            quantity: quantity,
            price: parseInt(input.dataset.price)
          });
        }
      });

      return items;
    }

    function updateBill() {
      const items = getSelectedItems();
      let total = 0;

      items.forEach(item => {
        total += item.price * item.quantity;
      });

      document.getElementById("billText").textContent = "Total Bill: Rs " + total;
    }

    async function placeOrder() {
      const name = document.getElementById("name").value.trim();
      const phone = document.getElementById("phone").value.trim();
      const paymentMethod = document.getElementById("paymentMethod").value;
      const items = getSelectedItems();

      if (!name || !phone) {
        showMessage("Please enter customer name and phone number.", "error");
        return;
      }

      if (items.length === 0) {
        showMessage("Please select at least one food item.", "error");
        return;
      }

      try {
        const res = await fetch("/place-order", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ name, phone, items, paymentMethod })
        });

        const data = await res.json();

        if (res.ok) {
          showMessage(data.message + " | Total: Rs " + data.total, "success");

          document.getElementById("name").value = "";
          document.getElementById("phone").value = "";

          document.querySelectorAll(".food-item input").forEach(input => {
            input.value = 0;
          });

          updateBill();
          loadOrders();
        } else {
          showMessage(data.message || "Order could not be placed.", "error");
        }

      } catch (error) {
        showMessage("Server error. Please try again.", "error");
      }
    }

    async function loadOrders() {
      try {
        const res = await fetch("/orders");
        const orders = await res.json();

        let output = "";

        if (!orders.length) {
          output = "<p>No orders found yet.</p>";
        } else {
          orders.forEach(o => {
            output += `
              <div class="order-item">
                <h4>${o.name}</h4>
                <p><strong>Phone:</strong> ${o.phone}</p>
                <p><strong>Food:</strong> ${o.food}</p>
                <p><strong>Quantity:</strong> ${o.quantity}</p>
                <p><strong>Total Price:</strong> Rs ${o.total_price}</p>
                <span class="badge">${o.payment_method}</span>
              </div>
            `;
          });
        }

        document.getElementById("orders").innerHTML = output;

      } catch (error) {
        document.getElementById("orders").innerHTML = "<p>Could not load orders.</p>";
      }
    }

    updateBill();
    loadOrders();
  </script>
</body>
</html>
